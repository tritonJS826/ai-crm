{
  "name": "br-general-python",
  "version": "1.0.0",
  "description": "Python backend for brain100 project (FastAPI + Prisma)",
  "type": "module",
  "main": "app/run.py",
  "scripts": {
    "installAll": "python -m venv .venv && .venv\\Scripts\\pip install --upgrade pip && .venv\\Scripts\\pip install -r requirements.txt && .venv\\Scripts\\python -m prisma py fetch",
    "prisma:generate": ".venv\\Scripts\\python -m prisma generate",
    "prisma:migrate": ".venv\\Scripts\\python -m prisma migrate deploy",
    "prisma:reset": ".venv\\Scripts\\python -m prisma migrate reset --force --skip-generate",
    "start": "pnpm run prisma:generate && .venv\\Scripts\\python -m app.run",
    "py:lint": ".venv\\Scripts\\ruff check br-general-python",
    "py:lint:fix": ".venv\\Scripts\\ruff check --fix --exit-non-zero-on-fix br-general-python",
    "py:format": ".venv\\Scripts\\ruff format br-general-python",
    "type-check": ".venv\\Scripts\\mypy br-general-python"
  },
  "keywords": [
    "python",
    "fastapi",
    "prisma",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "prisma": "^5.17.0",
    "ruff": "1.5.4"
  }
}
